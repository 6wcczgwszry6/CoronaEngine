--- G3: offline_actors 条目永不清除 ---
文件: src/systems/geometry/geometry_system.cpp
引入: commit 1c7d7a13

问题: actor 从所有场景移除后，offline_actors 中的条目永不清理 → 慢泄漏。

修复: actor 从场景移除时检查是否还存在于其他场景，若否，清理 offline_actors。

--- a/src/systems/geometry/geometry_system.cpp
+++ b/src/systems/geometry/geometry_system.cpp
@@ -243,6 +243,11 @@ void GeometrySystem::update() {
             auto it = scene_state.actor_load_states.begin();
             while (it != scene_state.actor_load_states.end()) {
                 if (!current_actors.count(it->first)) {
+                    // 检查 actor 是否还存在于其他场景，若否，清理全局状态
+                    bool exists_elsewhere = false;
+                    for (auto& [other_scene, other_state] : impl_->scenes) {
+                        if (other_state.actor_load_states.count(it->first)) { exists_elsewhere = true; break; }
+                    }
+                    if (!exists_elsewhere) {
+                        impl_->offline_actors.erase(it->first);
+                    }
                     scene_state.loading_tasks.erase(it->first);
                     scene_state.unloading_tasks.erase(it->first);
                     scene_state.unload_retry_counts.erase(it->first);


