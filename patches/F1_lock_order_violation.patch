=== F1 [致命] on_evict_requested 锁顺序违反 → 死锁风险 ===
文件: src/systems/geometry/geometry_system.cpp
引入: commit 1c7d7a13

问题: 文档规定锁顺序 impl_->mtx → Storage 锁, 但 on_evict_requested
     在 impl_->mtx 之前拿了 Storage 读锁。update() 持 impl_->mtx
     等待 Storage 写锁时会死锁。

修复: 把 Storage 读取移到 impl_->mtx 内部，先拿 impl_->mtx 再读 Storage。
      同时顺带修复 last_snapshot_time 的数据竞争（S1）。

--- a/src/systems/geometry/geometry_system.cpp
+++ b/src/systems/geometry/geometry_system.cpp
@@ -1365,6 +1365,11 @@ void GeometrySystem::on_evict_requested(const Events::ActorEvictRequestedEvent&
     impl_->ensure_actor_cache();

     auto& hub = SharedDataHub::instance();
+
+    // 先拿 impl_->mtx（锁顺序：impl_->mtx → Storage）
+    // 在锁内做防抖检查 + 状态修改，避免与 update() 死锁
+    std::unique_lock lock(impl_->mtx);
+
     const auto now = std::chrono::steady_clock::now();

     // ---- 第 1 步：防抖检查（5 秒内不重复快照） ----
@@ -1373,12 +1378,13 @@ void GeometrySystem::on_evict_requested(const Events::ActorEvictRequestedEvent&
         auto it = impl_->last_snapshot_time.find(event.actor);
         if (it != impl_->last_snapshot_time.end()) {
             auto elapsed = std::chrono::duration_cast<std::chrono::seconds>(now - it->second);
+            lock.unlock();
             if (elapsed.count() < 5) return;
         }
     }

     // ---- 第 2 步：读取 actor 和 transform 数据 ----
-    auto actor_read = hub.actor_storage().try_acquire_read(event.actor);
+    auto actor_read = hub.actor_storage().try_acquire_read(event.actor);  // OK: Storage 锁在 impl_->mtx 之后
     if (!actor_read) return;

     Corona::Cache::ActorSnapshot snap;
@@ -1424,14 +1430,11 @@ void GeometrySystem::on_evict_requested(const Events::ActorEvictRequestedEvent&
     // 改为加入 pending_gpu_releases 集合，在下一帧 update() 头部释放。
     {
-        std::unique_lock lock(impl_->mtx);
         impl_->offline_actors[event.actor] = true;
         impl_->pending_gpu_releases.insert(event.actor);
         auto scene_it = impl_->scenes.find(event.scene);
         if (scene_it != impl_->scenes.end()) {
             scene_it->second.actor_load_states[event.actor] = ActorLoadState::Unloaded;
         }
+        impl_->last_snapshot_time[event.actor] = now;  // 在锁内写入，修复 S1 数据竞争
     }
-
-    impl_->last_snapshot_time[event.actor] = now;
-
     CFW_LOG_NOTICE("[GeometrySystem] Actor {} evicted: cached snapshot ({} profiles, path={})",