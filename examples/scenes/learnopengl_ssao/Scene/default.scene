[base]
name = LearnOpenGL SSAO

[sun]
enabled = true
sun_direction = 1, 10, 1

[actors]
Floor.actor_type = model
Floor.name = Floor
Floor.route = Resource/floor.obj
Floor.actor_guid = learnopengl-ssao-floor
Floor.follow_camera = false
Floor.mechanics.physics_enabled = false
Floor.geometry.position = 0, -1, 0
Floor.geometry.rotation = 0, 0, 0
Floor.geometry.scale = 7.5, 1, 7.5
Nanosuit.actor_type = model
Nanosuit.name = Nanosuit
Nanosuit.route = Resource/nanosuit/nanosuit.obj
Nanosuit.actor_guid = learnopengl-ssao-nanosuit
Nanosuit.follow_camera = false
Nanosuit.mechanics.physics_enabled = false
Nanosuit.geometry.position = 0, -0.5, 0
Nanosuit.geometry.rotation = 1.60000002, 0, 0
Nanosuit.geometry.scale = 7, 7, 7

[scripts]
path = Scripts/scene_script.py

[terrain]
type =
path =

[grid]
enabled = true

[camera]
count = 1
active_id = ssao_camera
camera0.id = ssao_camera
camera0.name = default_MainCamera
camera0.deletable = false
camera0.position = 0.0000, 1.2000, -6.0000
camera0.forward = 0.0000, -0.1000, 1.0000
camera0.world_up = 0.0000, 1.0000, 0.0000
camera0.fov = 45.00
camera0.width = 1821
camera0.height = 1126
camera0.output_mode = final_color
camera0.render_backend = native
camera0.vision_render_mode = path_tracing
camera0.move_speed = 1.0
camera0.view_open = false
camera0.view_x = 120
camera0.view_y = 120
camera0.view_width = 960
camera0.view_height = 540

